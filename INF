-- Draggable functionality (titleBar)
local dragging = false
local dragStart = nil
local startPos = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

titleBar.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Elephant Toggle Logic
elephantButton.MouseButton1Click:Connect(function()
    toggles.Elephant = not toggles.Elephant
    if toggles.Elephant then
        elephantButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        elephantButton.Text = "Auto Elephant: ON"
    else
        elephantButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        elephantButton.Text = "Auto Elephant: OFF"
        if elephantConnection then
            elephantConnection:Disconnect()
            elephantConnection = nil
        end
    end
end)

-- Divine Toggle Logic
divineButton.MouseButton1Click:Connect(function()
    toggles.DivineBlock = not toggles.DivineBlock
    if toggles.DivineBlock then
        divineButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        divineButton.Text = "Auto Divine Block: ON"
    else
        divineButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        divineButton.Text = "Auto Divine Block: OFF"
        if divineConnection then
            divineConnection:Disconnect()
            divineConnection = nil
        end
    end
end)

