-- Button maker function
local function makeBtn(name, callback)
    local b = Instance.new("TextButton", sf)
    b.Size = UDim2.new(1, 0, 0, 28)
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    b.Text = name
    b.TextColor3 = Color3.fromRGB(200, 200, 200)
    b.TextSize = 11
    b.Font = Enum.Font.GothamBold
    b.BorderSizePixel = 0
    local corner = Instance.new("UICorner", b)
    corner.CornerRadius = UDim.new(0, 4)
    b.MouseButton1Click:Connect(function()
        b.BackgroundColor3 = Color3.fromRGB(60, 30, 120)
        pcall(callback)
        task.wait(0.3)
        b.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    end)
end

-- Toggle maker function
local function tog(name, key)
    local b = Instance.new("TextButton", sf)
    b.Size = UDim2.new(1, 0, 0, 28)
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    b.Text = name .. ": OFF"
    b.TextColor3 = Color3.fromRGB(200, 200, 200)
    b.TextSize = 11
    b.Font = Enum.Font.GothamBold
    b.BorderSizePixel = 0
    local corner = Instance.new("UICorner", b)
    corner.CornerRadius = UDim.new(0, 4)
    b.MouseButton1Click:Connect(function()
        E[key] = not E[key]
        b.BackgroundColor3 = E[key] and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(255, 0, 0)
        b.Text = name .. ": " .. (E[key] and "ON" or "OFF")
        if not E[key] and key == "Elephant" and elephantConnection then
            elephantConnection:Disconnect()
            elephantConnection = nil
        elseif not E[key] and key == "DivineBlock" and divineConnection then
            divineConnection:Disconnect()
            divineConnection = nil
        end
    end)
end

